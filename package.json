{
  "name": "zeno",
  "version": "0.1.0",
  "description": "Zero-dependency TypeScript web framework",
  "type": "module",
  "module": "index.ts",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters/index.js",
      "types": "./dist/adapters/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "typescript": "^5.0.0",
    "@types/node": ">=18"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    },
    "@types/node": {
      "optional": true
    }
  },
  "bin": {
    "zeno": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "jest"
  }
}
